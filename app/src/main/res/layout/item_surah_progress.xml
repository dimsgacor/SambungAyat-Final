<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/card_radius"
    app:cardBackgroundColor="@color/surface_container_lowest"
    app:cardElevation="0dp"
    app:strokeColor="@color/outline_variant"
    app:strokeWidth="1dp"
    android:layout_marginBottom="@dimen/spacing_stack"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Row 1: nama + status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_xs">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSurahName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Al-Fatihah"
                    android:textSize="@dimen/text_body_lg"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvVerseCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7 ayat"
                    android:textSize="@dimen/text_body_md"
                    android:textColor="@color/on_surface_variant" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvStatusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Lulus"
                android:textSize="@dimen/text_body_md"
                android:textColor="@color/primary"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Row 2: progress bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:progress="0"
            android:progressTint="@color/secondary_fixed_dim"
            android:progressBackgroundTint="@color/surface_container"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <!-- Row 3: progress label -->
        <TextView
            android:id="@+id/tvProgressLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100% Completed"
            android:textSize="@dimen/text_body_md"
            android:textColor="@color/on_surface_variant" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
